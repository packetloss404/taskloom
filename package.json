{
  "name": "taskloom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta -k --raw \"node --import tsx --watch src/server.ts\" \"vite --config web/vite.config.ts\"",
    "dev:api": "node --import tsx --watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run typecheck && npm test",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node --import tsx src/server.ts",
    "db:migrate": "node --import tsx src/db/cli.ts migrate",
    "db:status": "node --import tsx src/db/cli.ts status",
    "db:backup": "node --import tsx src/db/cli.ts backup",
    "db:restore": "node --import tsx src/db/cli.ts restore",
    "db:seed": "node --import tsx src/db/cli.ts seed-db",
    "db:seed-app": "node --import tsx src/db/cli.ts seed-app",
    "db:backfill": "node --import tsx src/db/cli.ts backfill",
    "db:reset": "node --import tsx src/db/cli.ts reset-db",
    "db:reset-app": "node --import tsx src/db/cli.ts reset-app",
    "db:backfill-job-metric-snapshots": "node --import tsx src/db/cli.ts backfill-job-metric-snapshots",
    "db:verify-job-metric-snapshots": "node --import tsx src/db/cli.ts verify-job-metric-snapshots",
    "db:backfill-alert-events": "node --import tsx src/db/cli.ts backfill-alert-events",
    "db:verify-alert-events": "node --import tsx src/db/cli.ts verify-alert-events",
    "store:seed": "node --import tsx src/db/cli.ts seed-store",
    "store:reset": "node --import tsx src/db/cli.ts reset-store",
    "jobs:recompute-activation": "node --import tsx src/jobs.ts recompute-activation",
    "jobs:repair-activation": "node --import tsx src/jobs.ts repair-activation-read-models",
    "jobs:cleanup-sessions": "node --import tsx src/jobs.ts cleanup-sessions",
    "jobs:export-workspace": "node --import tsx src/jobs.ts export-workspace",
    "jobs:reconcile-invitation-emails": "node --import tsx src/jobs.ts reconcile-invitation-emails",
    "jobs:snapshot-metrics": "node --import tsx src/jobs.ts snapshot-job-metrics",
    "access-log:rotate": "node --import tsx src/security/access-log-rotate-cli.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "test": "npm run test:api && npm run test:web",
    "test:api": "node --import tsx --test src/**/*.test.ts",
    "test:web": "tsx --tsconfig web/tsconfig.json --test web/src/**/*.test.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@hono/node-server": "^1.13.8",
    "clsx": "^2.1.1",
    "hono": "^4.9.2",
    "lucide-react": "^0.542.0",
    "openai": "^6.34.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "optionalDependencies": {
    "playwright": "^1.59.1"
  }
}
