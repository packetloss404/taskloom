{
  "name": "taskloom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta -k --raw \"node --import tsx --watch src/server.ts\" \"vite --config web/vite.config.ts\"",
    "dev:api": "node --import tsx --watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run typecheck && npm test",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node --import tsx src/server.ts",
    "jobs:recompute-activation": "node --import tsx src/jobs.ts recompute-activation",
    "jobs:cleanup-sessions": "node --import tsx src/jobs.ts cleanup-sessions",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "clsx": "^2.1.1",
    "hono": "^4.9.2",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "@types/node": "^24.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
