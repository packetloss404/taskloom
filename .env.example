# Copy to .env for local development. Do not commit real secrets.

NODE_ENV=development
PORT=8484

# Required when NODE_ENV=production. Use a long random passphrase.
MASTER_KEY=

# Persistence: json, sqlite, or postgres.
TASKLOOM_STORE=sqlite
TASKLOOM_DB_PATH=data/taskloom.sqlite
# TASKLOOM_DATABASE_URL=postgres://taskloom:change-me@postgres:5432/taskloom
# TASKLOOM_MANAGED_DATABASE_ADAPTER=postgres
# TASKLOOM_DATABASE_TOPOLOGY=single-writer

# Public-surface hardening.
TASKLOOM_TRUST_PROXY=false
TASKLOOM_RATE_LIMIT_KEY_SALT=
TASKLOOM_AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
TASKLOOM_AUTH_RATE_LIMIT_WINDOW_MS=60000
TASKLOOM_INVITATION_RATE_LIMIT_MAX_ATTEMPTS=20
TASKLOOM_INVITATION_RATE_LIMIT_WINDOW_MS=60000

# Sandbox execution. Production must use docker unless explicitly overriding
# the native host-shell guard for a trusted development environment.
TASKLOOM_SANDBOX_DRIVER=docker
TASKLOOM_SANDBOX_DEFAULT_RUNTIME=node-20
TASKLOOM_SANDBOX_DEFAULT_TIMEOUT_MS=120000
TASKLOOM_SANDBOX_MEMORY_MB=512
TASKLOOM_SANDBOX_CPUS=1
# TASKLOOM_ALLOW_INSECURE_NATIVE_SANDBOX=true

# Browser/sandbox artifacts are public files when served. In production this is
# disabled unless explicitly enabled.
TASKLOOM_ARTIFACT_SERVING_ENABLED=false
TASKLOOM_ARTIFACTS_PATH=data/artifacts

# Optional model providers. Configure only the providers you use.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MINIMAX_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Optional distributed rate limiter.
# TASKLOOM_DISTRIBUTED_RATE_LIMIT_URL=
# TASKLOOM_DISTRIBUTED_RATE_LIMIT_SECRET=
# TASKLOOM_DISTRIBUTED_RATE_LIMIT_TIMEOUT_MS=750
# TASKLOOM_DISTRIBUTED_RATE_LIMIT_FAIL_OPEN=false
