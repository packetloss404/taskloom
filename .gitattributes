# Normalize line endings. Text files are stored as LF in the repository and
# checked out as LF on every platform. This prevents the CRLF/LF churn that
# otherwise shows entire files as "modified" on Windows/WSL checkouts.
* text=auto eol=lf

# Shell scripts must always be LF (a CRLF shebang line breaks execution).
*.sh text eol=lf
*.mjs text eol=lf

# Windows scripts keep CRLF.
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.sqlite binary
*.sqlite-wal binary
*.sqlite-shm binary
*.db binary
